axira-drive-bot/oauth-credentials.json
axira-drive-bot/service-account.json
axira-drive-bot/token.json
axira-drive-bot/venv/
axira-drive-bot/*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
